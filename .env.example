# FYLO environment configuration
# Copy this file to .env and fill in your values.

# Root directory for FYLO data files (default: ./.fylo-data)
FYLO_ROOT=

# Enable logging (set to "1" to enable)
FYLO_LOGGING=

# Schema validation mode (set to "1" for strict mode)
FYLO_STRICT=

# Path to schema directory (collection schemas, manifest files, upgraders)
FYLO_SCHEMA_DIR=

# Schema directory for @d31ma/chex direct usage (same as FYLO_SCHEMA_DIR)
CHEX_SCHEMA_DIR=

# Encryption key for field-level encryption (optional)
FYLO_ENCRYPTION_KEY=

# Salt for cipher blind index derivation (optional)
FYLO_CIPHER_SALT=

# ── S3 client index backend (optional) ──────────────────
# Set these to use S3-compatible storage for the prefix index.
# Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO, etc.

# FYLO_S3_ACCESS_KEY_ID=
# FYLO_S3_SECRET_ACCESS_KEY=
# FYLO_S3_SESSION_TOKEN=
# FYLO_S3_ENDPOINT=
# FYLO_S3_REGION=
# FYLO_S3_BUCKET_PREFIX=
