{
    "version": 1,
    "roles": [
        {
            "name": "admin",
            "apply_when": { "$in": ["admin", "%%user.roles"] },
            "read": {
                "filter": {}
            },
            "insert": { "predicate": true },
            "update": {
                "filter": {},
                "fields": ["title"]
            },
            "delete": {
                "filter": {}
            }
        },
        {
            "name": "reader",
            "apply_when": true,
            "read": {
                "filter": { "tenantId": "%%user.tenantId" }
            },
            "insert": { "predicate": true },
            "update": {
                "filter": { "tenantId": "%%user.tenantId" }
            },
            "delete": {
                "filter": { "tenantId": "%%user.tenantId" }
            }
        }
    ]
}
