{
    "auth": {
        "allowed": {
            "version": 1,
            "roles": [
                {
                    "name": "writer",
                    "apply_when": { "$eq": ["%%user.subjectId", "user-1"] },
                    "read": { "filter": { "tenantId": "%%user.tenantId" } },
                    "insert": { "predicate": true },
                    "update": { "filter": { "tenantId": "%%user.tenantId" } },
                    "allow_actions": ["collection:create", "bulk:export"]
                }
            ]
        },
        "denied": {
            "version": 1,
            "roles": []
        }
    }
}
