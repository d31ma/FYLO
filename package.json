{
    "name": "@d31ma/fylo",
    "version": "26.30.04",
    "private": true,
    "packageManager": "bun@1.3.11",
    "type": "module",
    "bin": {
        "fylo": "src/cli/index.js"
    },
    "scripts": {
        "vendor:install": "sh ./scripts/install-vendor-bins.sh",
        "build:exe": "mkdir -p ./dist-bin && bun build --compile ./src/cli/index.js --outfile ./dist-bin/fylo",
        "build:web": "bun ./scripts/build-browser.mjs",
        "build:web:wasm": "bun ./scripts/build-browser.mjs --wasm",
        "test": "bun --env-file=tests/.env.test test tests/integration tests/collection tests/browser --timeout 120000",
        "test:par": "node ./scripts/test-parallel.mjs",
        "test:interop": "bun test tests/interop --timeout 120000 --parallel=1",
        "typecheck": "tsc --noEmit",
        "lint": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" README.md",
        "format": "prettier --write src tests"
    },
    "devDependencies": {
        "@types/bun": "^1.2.19",
        "@types/node": "^20.19.39",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^9.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/d31ma/Fylo.git"
    },
    "homepage": "https://fylo.del.ma",
    "license": "MIT",
    "keywords": [
        "storage",
        "database",
        "filesystem",
        "document-store",
        "javascript",
        "jsdoc",
        "executable"
    ],
    "author": "Chidelma",
    "bugs": {
        "url": "https://github.com/d31ma/Fylo/issues"
    }
}
